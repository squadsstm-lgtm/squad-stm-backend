# Server
server.port=8080

# Application
spring.application.name=Squad Backend
spring.mvc.pathmatch.use-trailing-slash-match=true

# MongoDB
spring.data.mongodb.uri=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
spring.data.mongodb.database=squads_stm

# JWT
jwt.secret=CHANGE_ME_IN_PRODUCTION
jwt.expiration=86400000

# Stripe
stripe.secret-key=sk_test_XXXX
stripe.publishable-key=pk_test_XXXX
stripe.webhook-secret=whsec_XXXX

# Email
spring.mail.host=smtp.ionos.co.uk
spring.mail.port=587
spring.mail.username=info@squadstm.co.uk
spring.mail.password=CHANGE_ME
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
mail.from=info@squadstm.co.uk

# URLs
app.frontend-url=http://localhost:4200
app.backend-url=http://localhost:8080/api

# CORS
app.cors-origins=http://localhost:4200

# Proxy
server.forward-headers-strategy=framework

# Firebase
firebase.config-path=classpath:serviceAccountKey.json

# Logging
logging.level.com.squad=INFO
logging.level.org.springframework.security=WARN
logging.level.org.springframework.web=WARN
logging.level.org.springframework.data.mongodb=WARN

# Encryption (AES-256, base64-encoded 32-byte key)
app.encryption.key=CHANGE_ME_BASE64_KEY
